    {
      "name": "Encounters",
      "description": "Clinical encounters / SOAP notes — the core clinical documentation module.",
      "item": [
        {
          "name": "Get Patient Encounters",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const encs = pm.response.json();",
                  "  if (encs.length > 0) {",
                  "    pm.collectionVariables.set('encounter_id', encs[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}" }] },
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/encounters/patient/{{patient_id}}", "host": ["{{base_url}}"], "path": ["api","v1","encounters","patient","{{patient_id}}"] },
            "description": "Returns all encounters for a specific patient, ordered by encounter_date DESC."
          }
        },
        {
          "name": "Create Encounter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('encounter_id', pm.response.json().id);",
                  "  pm.test('Encounter created', () => true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"appointment_id\": \"{{appointment_id}}\",\n  \"encounter_type\": \"Office Visit\",\n  \"chief_complaint\": \"Patient presents with chest pain and shortness of breath for 2 days.\",\n  \"subjective\": \"Patient reports sharp chest pain 7/10, worse with exertion. Denies fever.\",\n  \"objective\": \"BP: 145/92, HR: 88, RR: 18, SpO2: 97%. Lungs clear. No murmurs.\",\n  \"assessment\": \"Hypertensive urgency. R/O acute coronary syndrome.\",\n  \"plan\": \"Order EKG, troponin x3, CBC. Start amlodipine 5mg QD. Follow up in 48h.\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/encounters", "host": ["{{base_url}}"], "path": ["api","v1","encounters"] },
            "description": "Create a clinical encounter (SOAP note).\n\n**SOAP fields**:\n- `chief_complaint` — Patient's primary complaint in their own words\n- `subjective` — History of present illness, review of systems\n- `objective` — Vitals, physical exam findings, lab results\n- `assessment` — Clinical impression / diagnoses\n- `plan` — Treatment plan, orders, follow-up\n\n**Encounter types**: `Office Visit`, `Telehealth`, `Urgent Care`, `Annual Wellness`, `Procedure`, `Consult`\n\n**Status**: `open` (default), `signed`, `amended`"
          }
        },
        {
          "name": "Update Encounter",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{access_token}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"EKG normal. Troponin negative x3. Discharged with amlodipine 5mg. Follow-up in 1 week.\",\n  \"status\": \"signed\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/encounters/{{encounter_id}}", "host": ["{{base_url}}"], "path": ["api","v1","encounters","{{encounter_id}}"] }
          }
        }
      ]
    },
